# Required, set your Cursor API key (from cursor.com/dashboard/integrations).
CURSOR_API_KEY=

# Required, your GitHub repo URL for the Cursor Cloud Agent.
CURSOR_REPO_URL=https://github.com/YOUR_ORG/salesforce-agent

# Optional, branch for the Cloud Agent to use (default: main).
# CURSOR_REPO_BRANCH=main

# Optional, model to use (default: composer-2).
# CURSOR_MODEL=composer-2

# Required for Slack (Socket Mode).
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Salesforce OAuth 2.0 JWT Bearer Flow Configuration
# NOTE: For production, add these as Cursor Secrets (cursor.com/dashboard/cloud-agents)
# so the Cloud Agent VM can access them.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_PRIVATE_KEY=
